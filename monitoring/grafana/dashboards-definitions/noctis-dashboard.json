{
  "__inputs": [],
  "__requires": [],
  "title": "Noctis — Testnet Overview",
  "uid": "noctis-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["noctis", "stellar", "testnet"],
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "title": "Overall Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "up{job=\"noctis-health\"}",
          "legendFormat": "Health Check"
        }
      ]
    },
    {
      "title": "RPC Connection Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "up{job=\"stellar-rpc\"}",
          "legendFormat": "Stellar RPC"
        }
      ]
    },
    {
      "title": "Contract Health — Payroll Dispatcher",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "description": "ZK Payroll Dispatcher contract"
    },
    {
      "title": "Contract Health — Streaming Vault",
