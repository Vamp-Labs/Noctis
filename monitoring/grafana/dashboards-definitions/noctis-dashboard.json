    {
      "title": "Contract Health — Wallet Factory",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 4 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "description": "Smart Wallet Factory contract"
    },
    {
      "title": "Contract Health — Yield Router",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 4 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "description": "Yield Router contract"
    },
    {
      "title": "Contract Health — Policy Signer",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 12, "y": 4 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "description": "Policy Signer Module contract"
    },
    {
      "title": "Latest Ledger Sequence",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "description": "Latest Stellar testnet ledger sequence number"
    },
    {
      "title": "Active Streams (placeholder)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 7 },
      "id": 9,
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 800 }
            ]
          }
        }
      },
      "description": "Number of active payment streams",
      "targets": [
        {
          "expr": "0",
          "legendFormat": "active_streams"
        }
      ]
    },
    {
      "title": "Claim Volume 24h (placeholder)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 4, "y": 7 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "Number of claims in the last 24 hours / 7 days",
      "targets": [
        { "expr": "0", "legendFormat": "24h claims" }
      ]
    },
    {
      "title": "Total Value Locked (placeholder)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 7 },
      "id": 11,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyXLM",
          "decimals": 2
        }
      },
      "description": "Total XLM locked across all employers",
      "targets": [
        { "expr": "0", "legendFormat": "TVL" }
      ]
    },
    {
      "title": "Error Rate (placeholder)",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 13 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "description": "Transaction failure rate from Stellar RPC",
      "targets": [
        { "expr": "0", "legendFormat": "error_rate" }
      ]
    }
  ],
  "refresh": "60s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}
